{
  "name": "mac-seek",
  "title": "Seek",
  "description": "Semantic file search — find files by natural language description",
  "icon": "command-icon.png",
  "author": "kinwahlai",
  "categories": [
    "Productivity"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "seek",
      "title": "Seek Files",
      "description": "Find files by describing what you remember",
      "mode": "view",
      "arguments": [
        {
          "name": "query",
          "placeholder": "describe the file...",
          "type": "text",
          "required": false
        }
      ]
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.80.0",
    "@raycast/utils": "^1.17.0",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.0",
    "@types/node": "20.8.10",
    "@types/react": "^19.2.14",
    "eslint": "^8.51.0",
    "typescript": "^5.2.2"
  },
  "scripts": {
    "dev": "ray develop",
    "build": "ray build -e dist",
    "lint": "ray lint"
  }
}
